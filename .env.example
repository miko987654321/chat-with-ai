# --- Required ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- Optional, for `docker compose up` ---
DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324:free
ALLOWED_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000
APP_NAME=Chat with AI
CONTEXT_THRESHOLD_TOKENS=6000
KEEP_RECENT_MESSAGES=8

# Public backend URL the BROWSER will hit. In production set this to your domain
# (e.g. https://api.example.com). It is baked into the static frontend bundle.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Host port mappings.
BACKEND_PORT=8080
FRONTEND_PORT=3000

# --- For docker compose pull (CI/CD) ---
# GITHUB_REPOSITORY=username/chat-with-ai
# IMAGE_TAG=latest
