# --- Required ---
OPENROUTER_API_KEY=sk-or-v1-...

# --- Optional ---
PORT=8080
DB_PATH=./data/chat.db

# Default LLM model. Must be a free model on OpenRouter (suffix :free).
DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324:free

# Comma-separated list of CORS origins permitted to call this API.
ALLOWED_ORIGINS=http://localhost:3000

# Used in OpenRouter request headers (HTTP-Referer, X-Title) — appears in your OpenRouter usage page.
APP_URL=http://localhost:3000
APP_NAME=Chat with AI

# Once a chat exceeds this estimated token count, older messages are folded into a running summary.
CONTEXT_THRESHOLD_TOKENS=6000
# Number of most-recent messages always sent verbatim once a summary exists.
KEEP_RECENT_MESSAGES=8
